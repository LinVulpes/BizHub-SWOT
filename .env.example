# Environment Configuration for SWOT & AI Description Generator

# ============================================================================
# GOOGLE PLACES API
# ============================================================================
# Used for: Business enrichment, competitor analysis, review data
# Get your key at: https://console.cloud.google.com/google/maps-apis
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ============================================================================
# SERP API
# ============================================================================
# Used for: Competitor discovery, industry trends, social media scraping
# Get your key at: https://serpapi.com/
SERP_API_KEY=your_serpapi_key_here

# ============================================================================
# OPENAI API
# ============================================================================
# Used for: SWOT generation and AI Description Writer (when OpenAI selected)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# PERPLEXITY API
# ============================================================================
# Used for: SWOT generation and AI Description Writer (when Perplexity selected)
# Get your key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Port for backend server (optional, defaults to 3001)
PORT=3001

# ============================================================================
# NOTES
# ============================================================================
# 1. Copy this file to .env in the same directory
# 2. Replace the placeholder values with your actual API keys
# 3. Never commit .env to version control (add to .gitignore)
# 4. At minimum you need:
#    - OPENAI_API_KEY or PERPLEXITY_API_KEY (for LLM features)
#    - GOOGLE_PLACES_API_KEY and SERP_API_KEY (for enrichment features)
